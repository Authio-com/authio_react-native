{
  "name": "@useauthio/react-native",
  "version": "0.2.0",
  "description": "Authio React Native SDK — passwordless, multi-org auth with native passkeys.",
  "license": "MIT",
  "author": "Authio",
  "repository": {
    "type": "git",
    "url": "https://github.com/Authio-com/authio_react-native.git"
  },
  "homepage": "https://authio.com",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.mjs",
      "require": "./dist/hooks.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.mjs",
      "require": "./dist/provider.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": "*",
    "react": ">=18",
    "react-native": ">=0.74",
    "react-native-passkey": "*"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "react-native-passkey": {
      "optional": true
    },
    "@react-native-async-storage/async-storage": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "happy-dom": "^20.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "shell-quote@<1.8.4": ">=1.8.4",
      "esbuild": ">=0.28.1"
    }
  },
  "packageManager": "pnpm@10.12.1"
}
